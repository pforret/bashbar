# specific for weather.30m.sh
WEATHER_CITY="Brussels"    # any city name wttr.in accepts
WEATHER_UNIT="m"           # m=metric, u=imperial, M=metric+mph

# --- API Usage Plugin (apiusage.1h.sh) ---
# Admin keys enable spend tracking; regular keys only show "active" status.

# Get via https://openrouter.ai/workspaces/default/keys
OPENROUTER_API_KEY=

# Get via https://platform.openai.com/settings/organization/admin-keys
OPENAI_ADMIN_KEY=

# Get via https://platform.claude.com/settings/admin-keys
ANTHROPIC_ADMIN_KEY=

# Get via https://app.edenai.run/settings/api-keys
EDENAI_API_KEY=
